  "specVersion": "1.0.0-draft",
  "name": "status-light",
  "displayName": "Status light",
  "description": "Status lights describe the condition of an entity. They can be used to convey semantic meaning, such as statuses and categories.",
  "meta": {
    "category": "status",
    "documentationUrl": "https://spectrum.adobe.com/page/status-light/"
  },
  "documentBlocks": [
    {
      "type": "purpose",
      "content": "Status lights describe the condition of an entity. They can be used to convey semantic meaning, such as statuses and categories."
    },
    {
      "type": "guideline",
      "content": "Status lights indicate the state or condition of an item. They convey semantic meaning such as statuses and categories."
    },
    {
      "type": "guideline",
      "content": "Status lights should always include a label. Color alone is not enough to communicate the status."
    },
    {
      "type": "guideline",
      "content": "When status lights have a semantic meaning, they use semantic colors. Use these variants for the following statuses:"
    },
    {
      "type": "guideline",
      "content": "When status lights are used to color code categories and labels that are commonly found in data visualization, they use non-semantic label colors. The ideal usage for these is when there are 8 or fewer categories or labels being color coded."
    },
    {
      "type": "guideline",
      "content": "Status lights come in four different sizes: small, medium, large, and extra-large. The medium size is the default and most frequently used option. Use the other sizes sparingly; they should be used to create a hierarchy of importance within the page."
    },
    {
      "type": "guideline",
      "content": "When the text is too long for the horizontal space available, it wraps to form another line."
    },
    {
      "type": "guideline",
      "content": "Semantic status lights should never be used for color coding categories or labels, and vice versa."
    },
    {
      "type": "guideline",
      "content": "A status light should always include a label with text that clearly communicates about the kind of status being shown. Do not change the text color to match the dot."
    }
  ],
