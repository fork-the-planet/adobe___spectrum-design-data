  "files": [
    "components",
    "conformance",
    "fields",
    "rules",
    "schemas",
    "spec",
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "ava"
  },
  "devDependencies": {
    "ava": "^6.0.1"
  }
